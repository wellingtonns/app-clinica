generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String   @default("")
  role      String   @default("Administrador")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Patient {
  id                  String @id
  fullName            String
  birthDate           String @default("")
  cpf                 String @default("")
  phone               String @default("")
  email               String @default("")
  address             String @default("")
  generalObservations String @default("")
  allergySummary      String @default("")
  restrictionSummary  String @default("")
  status              String @default("Ativo")
  createdAt           String
  updatedAt           String

  appointments     Appointment[]
  medicalRecords   MedicalRecord[]
  anamneses        AnamnesisRecord[]
  contracts        ContractRecord[]
  procedures       ProcedureRecord[]
  patientFiles     PatientFileRecord[]
  financialEntries FinancialEntry[]

  @@index([fullName])
  @@index([status])
  @@index([updatedAt])
}

model Professional {
  id             String @id
  name           String
  specialty      String @default("")
  role           String @default("Profissional")
  commissionRate String @default("")
  nextShift      String @default("")
  phone          String @default("")
  email          String @default("")
  council        String @default("")
  status         String @default("Ativo")

  appointments Appointment[]
  procedures   ProcedureRecord[]

  @@index([name])
  @@index([specialty])
  @@index([status])
}

model Appointment {
  id               String  @id
  patientId        String
  professionalId   String
  procedure        String
  date             String
  time             String
  originalDate     String?
  originalTime     String?
  rescheduleReason String?
  isRescheduled    Boolean @default(false)
  durationMinutes  Int
  status           String
  paymentStatus    String  @default("Pendente")
  paymentMethod    String  @default("")
  paymentDate      String  @default("")
  paidAmount       Float   @default(0)
  installments     Int?
  notes            String  @default("")
  price            Float   @default(0)
  history          Json    @default("[]")
  attendanceStartedAt                    String @default("")
  attendanceFinishedAt                   String @default("")
  attendanceDurationMinutes              Int?
  attendanceProcedureDescription         String @default("")
  attendanceProductsUsed                 String @default("")
  attendanceClinicalNotes                String @default("")
  attendancePostProcedureRecommendations String @default("")
  attendanceNextReturn                   String @default("")
  attendanceEvolution                    String @default("")

  patient          Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  professional     Professional     @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  payment          Payment?
  medicalRecords   MedicalRecord[]
  financialEntries FinancialEntry[]

  @@index([date, time])
  @@index([professionalId, date])
}

model MedicalRecord {
  id              String @id
  patientId       String
  appointmentId   String?
  professionalId  String?
  date            String
  scheduledTime   String @default("")
  status          String @default("Finalizado")
  procedure       String
  startedAt       String @default("")
  finishedAt      String @default("")
  durationMinutes Int?
  clinicalNotes   String @default("")
  recommendations String @default("")
  productsUsed    String @default("")
  nextReturn      String @default("")
  evolution       String @default("")
  createdAt       String
  updatedAt       String

  patient     Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([patientId, date])
  @@index([appointmentId])
  @@index([professionalId])
}

model Payment {
  id            String @id
  appointmentId String @unique
  status        String
  method        String @default("")
  paymentDate   String @default("")
  amount        Float
  paidAmount    Float  @default(0)
  balanceAmount Float  @default(0)
  installments  Int?

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

model FinancialEntry {
  id            String  @id
  type          String
  appointmentId String?
  productId     String?
  patientId     String?
  procedure     String?
  productName   String?
  description   String
  date          String
  amount        Float
  paidAmount    Float
  balanceAmount Float
  status        String
  paymentMethod String
  paymentDate   String
  installments  Int?
  source        String

  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  product     Product?     @relation(fields: [productId], references: [id], onDelete: Cascade)
  patient     Patient?     @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([type, date])
  @@index([date, description])
  @@index([status, date])
  @@index([paymentMethod])
  @@index([patientId])
  @@index([appointmentId])
  @@index([productId])
}

model Product {
  id           String @id
  name         String
  category     String @default("")
  sku          String @default("")
  batch        String @default("")
  expiry       String @default("")
  price        Float  @default(0)
  stock        Float  @default(0)
  minimumStock Float  @default(0)
  unit         String @default("")
  unitCost     Float  @default(0)
  purchaseDate String @default("")
  supplier     String @default("")
  description  String @default("")

  financialEntries FinancialEntry[]
  stockMovements   StockMovement[]

  @@index([name])
  @@index([category])
  @@index([purchaseDate])
}

model StockMovement {
  id          String   @id @default(cuid())
  productId   String
  type        String
  quantity    Float
  unitCost    Float
  totalCost   Float
  date        String
  description String   @default("")
  createdAt   DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, date])
}

model AnamnesisRecord {
  id                       String @id
  patientId                String
  version                  Int
  createdAt                String
  updatedAt                String
  updatedBy                String
  healthHistory            String @default("")
  priorDiseases            String @default("")
  surgeries                String @default("")
  treatments               String @default("")
  allergies                String @default("")
  medications              String @default("")
  habits                   String @default("")
  mainComplaint            String @default("")
  professionalObservations String @default("")
  checkboxes               Json   @default("{}")
  attachments              Json   @default("[]")

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, version])
}

model ContractRecord {
  id           String @id
  patientId    String
  version      Int
  contractType String @default("")
  signedAt     String @default("")
  observations String @default("")
  file         Json
  uploadedAt   String

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, version])
}

model ProcedureRecord {
  id             String  @id
  patientId      String
  name           String
  procedureType  String  @default("")
  date           String
  professionalId String?
  observations   String  @default("")
  photos         Json    @default("[]")

  patient      Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  professional Professional? @relation(fields: [professionalId], references: [id], onDelete: SetNull)

  @@index([date, name])
  @@index([patientId, date])
  @@index([professionalId, date])
}

model PatientFileRecord {
  id          String @id
  patientId   String
  category    String
  description String @default("")
  file        Json

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([category])
}
